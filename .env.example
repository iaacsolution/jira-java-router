# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=votre.email@domain.com
JIRA_API_TOKEN=votre_token_api_jira
JIRA_PROJECT=KAN
TOP_K=3

# Slack — rapport final (canal general, visible par l'equipe)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Slack — validation HITL (hitl_daily.py) — DOIT etre un canal PRIVE, distinct du
# webhook ci-dessus. Ce message affiche le contenu AVANT validation humaine (bloqueur,
# classes Java proposees, rapport d'impact) : si l'auteur du ticket Jira ou quelqu'un
# present au Daily peut lire ce canal, l'exfiltration n'est pas bloquee par le HITL,
# juste deplacee. Creer un canal Slack prive dedie + soit un Incoming Webhook separe
# (SLACK_HITL_WEBHOOK_URL) soit un Bot Token + SLACK_CHANNEL (chat.postMessage).
SLACK_HITL_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL=

# HITL (hitl_daily.py) — port fixe 8092 dans le code
HITL_URL=http://localhost:8092

# Ollama (transcription/embeddings) — utilise localhost si lance hors Docker
OLLAMA_BASE_URL=http://localhost:11434

# java-legacy-agent — pont vers l'analyse de breaking changes (mode "serve")
JAVA_AGENT_URL=http://localhost:8081
